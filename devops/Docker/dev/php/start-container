#!/bin/sh
set -e


#=============================================================#
#  Laravel / PHP-FPM Container Entrypoint Script
#-------------------------------------------------------------#
#  This script is executed when the container starts.
#  It:
#    1. Sets up UID and GID for proper file ownership.
#    2. Fixes file permissions for the application.
#    3. Ensures the .env file exists (copies from .env.example if not).
#    8. Starts PHP-FPM in the foreground.
#=============================================================#

#======#
#  1. Configure User and Group IDs
#------#
USER_ID=${UID:-1000}
GROUP_ID=${GID:-1000}


#======#
#  2. Fix File Ownership
#------#
echo "Fixing file permissions with UID=${USER_ID} and GID=${GROUP_ID}..."
chown -R ${USER_ID}:${GROUP_ID} /var/www/html || echo "Some files could not be changed"


#======#
#  3. Ensure .env File Exists
#------#
if [ ! -f /var/www/html/.env ]; then
    echo "No .env file found. Copying from .env.example..."
    cp /var/www/html/.env.example /var/www/html/.env
    chown ${USER_ID}:${GROUP_ID} /var/www/html/.env
else
    echo ".env file already exists. Skipping copy."
fi

#======#
#  8. Start PHP-FPM in Foreground
#------#
echo "Starting PHP-FPM..."
php-fpm -F


